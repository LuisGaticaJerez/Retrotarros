# Dependencias
node_modules/
.pnp
.pnp.js

# Build
dist/
build/
.next/
out/

# Entorno
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code
.claude/

# DOCX generados desde MD por sync-to-drive.ps1 (la fuente es el .md)
studio/pautas/*.docx

# MP3s precargados de pautas TarroBot (regenerables con --pauta-preload)
# Los JSON .tarrobot.json SI se versionan, son el guion del episodio
studio/pautas/audio/

# SRT exportados desde pautas (regenerables con --pauta-srt o /api/queue/srt)
studio/pautas/*.srt

# Muestras MP3 generadas por tarrobot-probar-voces.py (regenerables)
studio/voces-muestra/

# MIDI descargados de fan-sites (Ichigos, Ninsheetmusic) — son transcripciones
# por fans, NO redistribuimos en el repo publico. Cada usuario los baja para si.
# Cubrir tambien subcarpetas (arcade/ mario/ n64/ snes/ test/) — fix 2026-06-19.
studio/melodias/*.mid
studio/melodias/*.midi
studio/melodias/**/*.mid
studio/melodias/**/*.midi

# Soundfont SNES (~30 MB binario, lo descarga install.bat)
studio/melodias/*.sf2

# Capturas PNG generadas por capture-slides.py (la fuente es el HTML).
# Se regeneran con: python scripts/capture-slides.py <slug>
# studio/**/ (no solo studio/) porque desde la reorganizacion de 2026-07-21
# las carpetas captures/<slug>/ viven anidadas por categoria
# (studio/rankings/top-precios/captures/<slug>/, etc.), no solo en la raiz plana.
studio/**/captures/

# Backups generados por update-tagline-images.py
# El versionado del git es la historia, no necesitamos .bak.png al lado
assets/*.bak.png

# Cache local de transcripciones Whisper (regenerable, no versionar)
.cache/

# Slides HTML generados por TarroBot (regenerables desde data/tarrobot-database.json)
# Se regeneran con: python scripts/tarrobot.py <tema> --slide
studio/tarrobot-out/

# Build output del instalador (regenerable con build-package.ps1)
installers/tarrobot-studio/dist/

# Entornos virtuales Python (no versionar)
.venv/
venv/
ENV/
__pycache__/

# Binarios portables descargados por el instalador
bin/ffmpeg.exe
bin/ffprobe.exe

# FluidSynth bundle local (DLLs + exe) que descarga install.bat. Si Luis lo
# tiene en installers/tarrobot-studio/bin/, build-package.ps1 lo incluye en
# el ZIP, pero no lo versionamos en git (8 MB de binarios redistribuibles).
installers/tarrobot-studio/bin/

# Cache de session log y exports generados por TarroBot
studio/exports/*.txt
studio/shorts/*.mp3
studio/shorts/*.srt
studio/shorts/*.mp4
studio/shorts/audio/
studio/sessions/

# Bundle exportable del Claude del estudio (build, se regenera con Compress-Archive)
docs/handoff-claude-studio.zip

# ─── Studio Panel (Node/TypeScript monorepo absorbido como subcarpeta) ──
# Solo .env raiz y .env.local del studio-panel; los .env.example y similares
# se versionan normalmente.
studio-panel/.env
studio-panel/.env.local
studio-panel/.env.*.local
studio-panel/apps/*/.env
studio-panel/apps/*/.env.local

# node_modules del monorepo studio-panel
studio-panel/node_modules/
studio-panel/apps/*/node_modules/
studio-panel/packages/*/node_modules/

# Build output del studio-panel
studio-panel/apps/*/dist/
studio-panel/apps/*/.next/
studio-panel/apps/*/build/
studio-panel/apps/*/out/

# Backup del .env hecho al migrar (no se versiona)
studio-panel/.env.bak.*
studio-panel/.env.bak

# Memorias locales del studio-panel (cache de sesion claude code, no canonico)
studio-panel/.remember/tmp/
studio-panel/.remember/logs/

# Sprint 17-18: grabaciones OBS auto-record + teasers generados + capcut-ready.
# Son outputs locales del estudio, no versionables.
recordings/
studio/teasers/

# Runtime de TarroBot: estado/cache generado en ejecucion, NO versionable.
# OJO: NO ignorar data/tarrobot-database.json (esa SI es canonica). Fix 2026-06-19.
data/*.db
data/tarrobot-cache-llm.json
data/tarrobot-auto-respond.json
data/tarrobot-messages.db

# Audio de reaccion/SFX embebido en episodios (se distribuye por Drive, no git).
studio/img/**/*.mp3

# Memoria local del harness (Claude Code), no es del proyecto.
/.remember/
