# Studio Panel — variables de entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitear .env (está en .gitignore).

# --- Supabase ---
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Backend ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Twitch ---
# Para chat público anónimo NO necesitás credenciales (usa justinfan).
# Si quieres bot identificado (escribir en chat) o EventSub, completá:
TWITCH_BOT_USERNAME=
TWITCH_BOT_OAUTH=

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=

# --- Discord Bot ---
DISCORD_BOT_TOKEN=

# --- Frontend (Vite) ---
# Estas SI se exponen al cliente — solo poné cosas públicas.
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
