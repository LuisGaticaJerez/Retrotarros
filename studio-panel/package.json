{
  "name": "retrotarros-studio-panel",
  "version": "0.0.1",
  "private": true,
  "description": "Panel concentrador de mensajería multi-plataforma para streams/podcasts del estudio Retrotarros",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @retrostudio/backend run dev",
    "dev:frontend": "pnpm --filter @retrostudio/frontend run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.10.0"
  }
}
